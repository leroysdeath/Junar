# Leaderboard + feedback backend (Supabase), consumed ONLY by the Vercel Edge
# routes api/leaderboard.ts and api/feedback.ts. These are server-only secrets —
# they are NOT prefixed with VITE_, so Vite never bundles them into the client.
#
# Local dev: copy this file to .env.local (git-ignored) and run `vercel dev`
# (plain `vite dev` does not serve the api/ routes).
# Production: set the same vars in the Vercel Project Settings (where GITHUB_TOKEN
# already lives for api/crash.ts).

# Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Supabase service_role key (bypasses Row-Level Security). Server-only — never
# expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
